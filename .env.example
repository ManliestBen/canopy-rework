# Canopy server configuration.
# Copy to .env (kept out of git). All integrations are OPTIONAL — the app
# runs without any of them and shows each one as "not configured".

# --- Core ---
PORT=3000
# Where the SQLite database lives. Keep it OUTSIDE the repo in production.
# CANOPY_DB_PATH=/home/pi/.config/canopy/canopy.db

# --- Google Calendar (service account) ---
# Path to the service-account key file. Keep it outside the app directory,
# chmod 600. Share your Google calendars with the service account's email.
# GOOGLE_SERVICE_ACCOUNT_PATH=/home/pi/.config/canopy/service-account.json

# --- Gmail outbound (Canopy identity) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
# CANOPY_EMAIL_FROM=mackinaw.canopy@gmail.com

# --- Weather ---
# OPENWEATHERMAP_API_KEY=

# --- Photos ---
# CLOUDINARY_URL=cloudinary://key:secret@cloud_name
